{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@qaimodelbuilder/frontend",
  "private": true,
  "version": "3.0.0",
  "description": "QAIModelBuilder frontend — Vite + Vue 3 SFC (Clean Cutover rewrite)",
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,css,scss,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css,scss,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "stylelint": "stylelint \"src/**/*.{css,scss,vue}\"",
    "gen:types": "openapi-typescript ../tools/openapi/api-snapshot.json --root-types --root-types-no-schema-prefix -o src/types/api.ts"
  },
  "dependencies": {
    "vue": "^3.5.0",
    "vue-router": "^4.4.0",
    "pinia": "^2.2.0",
    "vue-i18n": "^10.0.0",
    "@vueuse/core": "^11.0.0",
    "marked": "^14.1.0",
    "highlight.js": "^11.10.0",
    "dompurify": "^3.1.0",
    "mermaid": "^11.0.0"
  },
  "devDependencies": {
    "vite": "^5.4.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "vue-tsc": "^2.1.0",
    "typescript": "~5.6.0",
    "@types/node": "^22.7.0",
    "@types/dompurify": "^3.0.0",
    "@types/marked": "^6.0.0",

    "openapi-typescript": "^7.4.0",

    "eslint": "^9.10.0",
    "@vue/eslint-config-typescript": "^14.1.0",
    "eslint-plugin-vue": "^9.28.0",
    "@typescript-eslint/parser": "^8.7.0",
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "globals": "^15.9.0",
    "prettier": "^3.3.0",
    "stylelint": "^16.9.0",
    "stylelint-config-standard": "^36.0.0",
    "stylelint-config-recommended-vue": "^1.5.0",

    "vitest": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0",
    "@vue/test-utils": "^2.4.0",
    "happy-dom": "^15.7.0",

    "@playwright/test": "^1.47.0",
    "playwright": "^1.47.0"
  },
  "// notes": "openapi-typescript generates frontend/src/types/api.ts from tools/openapi/api-snapshot.json (PR-050 §11.4 type sync). marked / highlight.js / dompurify are imported via npm; the legacy frontend/vendor/ runtime mounts are NOT used by this Vite app and will be deleted in S8 PR-081. Pinia replaces the scattered reactive stores in legacy frontend/js/. vue-router replaces the manual hash-route logic in legacy frontend/js/app.js. pnpm settings (overrides/patchedDependencies) live in pnpm-workspace.yaml since pnpm 10+ no longer reads the package.json \"pnpm\" key."
}
